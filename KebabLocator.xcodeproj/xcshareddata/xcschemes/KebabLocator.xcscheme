      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Download GoogleMobileAds dSYMs"
               scriptText = "#!/bin/sh&#10;# Download GoogleMobileAds + UserMessagingPlatform dSYMs&#10;# Fixes: &quot;Upload Symbols Failed&quot; during App Store validation&#10;TEMP=$(mktemp -d)&#10;echo &quot;Downloading GoogleMobileAds dSYMs...&quot;&#10;curl -sL &quot;https://dl.google.com/googleadmobadssdk/googlemobileadssdkios.zip&quot; -o &quot;$TEMP/gads.zip&quot; || { echo &quot;Download failed - skipping&quot;; exit 0; }&#10;unzip -q &quot;$TEMP/gads.zip&quot; -d &quot;$TEMP/out&quot;&#10;find &quot;$TEMP/out&quot; -name &quot;*.dSYM&quot; | while read D; do&#10;  echo &quot;Copying $(basename $D)&quot;&#10;  cp -rf &quot;$D&quot; &quot;$ARCHIVE_PATH/dSYMs/&quot;&#10;done&#10;rm -rf &quot;$TEMP&quot;&#10;echo &quot;dSYM copy done.&quot;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "7ED5EC053BD782372280ED97"
                     BuildableName = "KebabLocator.app"
                     BlueprintName = "KebabLocator"
                     ReferencedContainer = "container:KebabLocator.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
   </ArchiveAction>
