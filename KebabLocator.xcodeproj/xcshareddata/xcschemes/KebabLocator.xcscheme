      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Download GoogleMobileAds dSYMs"
               scriptText = "#!/bin/sh&#10;# Copia dSYMs dos XCFrameworks binarios do SPM para o arquivo&#10;# Corrige: &quot;Upload Symbols Failed&quot; para GoogleMobileAds + UserMessagingPlatform&#10;SOURCE_PACKAGES=$(find ~/Library/Developer/Xcode/DerivedData -name &quot;SourcePackages&quot; -maxdepth 4 2&gt;/dev/null | head -1)&#10;if [ -z &quot;$SOURCE_PACKAGES&quot; ]; then&#10;  echo &quot;SourcePackages nao encontrado, a ignorar&quot;&#10;  exit 0&#10;fi&#10;find &quot;$SOURCE_PACKAGES&quot; -name &quot;*.dSYM&quot; 2&gt;/dev/null | while read DSYM; do&#10;  NAME=$(basename &quot;$DSYM&quot;)&#10;  echo &quot;A copiar $NAME&quot;&#10;  cp -rf &quot;$DSYM&quot; &quot;$ARCHIVE_PATH/dSYMs/&quot;&#10;done&#10;echo &quot;dSYM copy concluido.&quot;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "7ED5EC053BD782372280ED97"
                     BuildableName = "KebabLocator.app"
                     BlueprintName = "KebabLocator"
                     ReferencedContainer = "container:KebabLocator.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
   </ArchiveAction>
